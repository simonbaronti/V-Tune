{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "V-Tune",
  "version": "0.1.0",
  "identifier": "app.vtune.tuner",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5183",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "V-Tune",
        "width": 1280,
        "height": 800,
        "minWidth": 480,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "theme": "Dark",
        "backgroundColor": "#08080c"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Music",
    "shortDescription": "Precision strobe tuner for handpans.",
    "longDescription": "V-Tune is a precision strobe tuner designed for handpans and other multi-modal instruments. It uses FFT peak detection plus phase-rate Goertzel analysis to give accurate, stable cents readings on each resonant mode.",
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
