# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Tauri — Rust build artifacts (regenerated by `npm run tauri:build`)
src-tauri/target
src-tauri/Cargo.lock.bak

# Capacitor / iOS — per-user Xcode state, build output, derived data
ios/App/Pods
ios/App/build
ios/App/Podfile.lock
ios/**/xcuserdata
ios/**/DerivedData
ios/**/*.xcuserstate
ios/capacitor-cordova-ios-plugins
ios/App/public

# Capacitor / Android — Gradle output
android/.gradle
android/build
android/app/build
android/.idea
android/local.properties
android/captures
# NOTE: gradle-wrapper.jar MUST be committed — it bootstraps the Gradle
# wrapper, and CI (which has no system Gradle) can't build without it.
# Do not re-add an ignore rule for it.

# macOS notarization credentials — NEVER commit
.env.notarize
src-tauri/.env.notarize

# Tauri update-signing key — NEVER commit
src-tauri/.tauri-signing.key
src-tauri/.tauri-signing.key.pub
